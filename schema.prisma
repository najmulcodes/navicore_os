// NAVICORE OS — Prisma schema skeleton, Phase 0 scope only.
//
// Scope: Core Platform (Workspace/RBAC layer) + Work Management + CRM & Sales.
// Out of scope until their own phases: Finance/Billing (5), Knowledge/Documents
// and pgvector-backed embeddings (4/6), Automation (7), Collaboration (8),
// Analytics (9).
//
// Ownership note: `User`, `Session`, `Account`, `Verification`, `Organization`,
// `Member`, and `Invitation` are owned and generated by Better Auth's
// organization plugin (see docs/adr/002-auth-provider.md). They are NOT
// hand-authored here — Phase 1 runs Better Auth's schema generator and merges
// its output with this file. Everything below is what NAVICORE OS adds on top
// of that base: Workspaces (a sub-org concept Better Auth doesn't provide),
// fine-grained Role/Permission, and the Work Management + CRM domain models.
// Every `userId`/`organizationId`/`ownerId`/`assigneeId`/`authorId` field below
// is a plain string FK to Better Auth's generated tables, not a Prisma
// `@relation` — that relation gets wired up once the actual generated model
// names are known in Phase 1.

generator client {
  provider = "prisma-client-js"
  output   = "../packages/db/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // `pgvector` extension is intentionally NOT enabled yet — see
  // docs/adr/003-orm-and-database.md. Add `extensions = [pgvector]` (and the
  // matching `previewFeatures = ["postgresqlExtensions"]` in the generator
  // block above) when Phase 4 introduces the first embedding column.
}

// ─────────────────────────────────────────────────────────────────────────
// Workspaces — NAVICORE's own concept, sits below Better Auth's Organization
// ─────────────────────────────────────────────────────────────────────────

model Workspace {
  id             String    @id @default(cuid())
  organizationId String // FK -> Better Auth Organization.id
  name           String
  slug           String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  members        WorkspaceMember[]
  projects       Project[]
  companies      Company[]
  contacts       Contact[]
  deals          Deal[]
  pipelineStages PipelineStage[]
  activityLogs   ActivityLog[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String // FK -> Better Auth User.id
  roleId      String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id])

  @@unique([workspaceId, userId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────
// RBAC — fine-grained permissions layered on top of Better Auth's org roles
// ─────────────────────────────────────────────────────────────────────────

model Role {
  id             String   @id @default(cuid())
  organizationId String? // null => system-defined role (Owner/Admin/Member/Guest), available to every org
  name           String
  isSystem       Boolean  @default(false)
  createdAt      DateTime @default(now())

  permissions      RolePermission[]
  workspaceMembers WorkspaceMember[]

  @@unique([organizationId, name])
}

model Permission {
  id     String @id @default(cuid())
  key    String @unique // e.g. "projects:create", "deals:manage_pipeline_stages" — see docs/PHASE_0_ARCHITECTURE.md §4
  module String // "org" | "workspace" | "projects" | "tasks" | "crm" | "deals" | "activity"
  action String // "create" | "read" | "update" | "delete" | module-specific verb

  roles RolePermission[]

  @@index([module])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ─────────────────────────────────────────────────────────────────────────
// Work Management
// ─────────────────────────────────────────────────────────────────────────

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

model Project {
  id          String        @id @default(cuid())
  workspaceId String
  name        String
  description String?
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  createdById String // FK -> Better Auth User.id
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  columns   TaskStatus[]
  tasks     Task[]

  @@index([workspaceId])
  @@index([workspaceId, status])
}

model TaskStatus {
  id        String  @id @default(cuid())
  projectId String
  name      String // "Backlog", "In Progress", "Done", ...
  order     Int
  isDefault Boolean @default(false)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, order])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id          String       @id @default(cuid())
  projectId   String
  statusId    String
  title       String
  description String?
  assigneeId  String? // FK -> Better Auth User.id
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  order       Int
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  project Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status  TaskStatus @relation(fields: [statusId], references: [id])

  @@index([projectId, statusId])
  @@index([assigneeId])
}

// ─────────────────────────────────────────────────────────────────────────
// Cross-cutting: Comments, Attachments, Activity
// ─────────────────────────────────────────────────────────────────────────

// Known Prisma limitation — polymorphic associations: Comment and Attachment
// need to attach to either a Task or a Deal. Prisma cannot express a single
// FK column pointing to one of two different target tables, so entityType +
// entityId are plain indexed scalar columns, not a Prisma @relation.
// Referential integrity for entityId is enforced in the application layer
// (the service validates entityId exists in the table entityType names,
// before insert). See docs/PHASE_0_ARCHITECTURE.md §3 and TECH_DEBT.md.
enum CommentableType {
  TASK
  DEAL
}

model Comment {
  id         String          @id @default(cuid())
  entityType CommentableType
  entityId   String
  authorId   String // FK -> Better Auth User.id
  body       String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  deletedAt  DateTime?

  @@index([entityType, entityId])
  @@index([authorId])
}

model Attachment {
  id           String          @id @default(cuid())
  entityType   CommentableType
  entityId     String
  storageKey   String // Supabase Storage object key
  fileName     String
  mimeType     String
  sizeBytes    Int
  uploadedById String
  createdAt    DateTime        @default(now())
  deletedAt    DateTime?

  @@index([entityType, entityId])
}

// Append-only — no deletedAt, no update path. Written by ActivityModule's
// domain-event listeners (see docs/PHASE_0_ARCHITECTURE.md §2).
model ActivityLog {
  id             String   @id @default(cuid())
  organizationId String
  workspaceId    String
  actorId        String // FK -> Better Auth User.id
  entityType     String // "project" | "task" | "deal" | "workspace_member" | ...
  entityId       String
  action         String // "created" | "updated" | "status_changed" | "deleted" | ...
  metadata       Json?
  createdAt      DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([entityType, entityId])
}

// ─────────────────────────────────────────────────────────────────────────
// CRM & Sales
// ─────────────────────────────────────────────────────────────────────────

model Company {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  domain      String?
  industry    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts  Contact[]
  deals     Deal[]

  @@index([workspaceId])
}

model Contact {
  id          String    @id @default(cuid())
  workspaceId String
  companyId   String?
  firstName   String
  lastName    String
  email       String?
  phone       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company   Company?  @relation(fields: [companyId], references: [id])
  deals     Deal[]

  @@index([workspaceId])
  @@index([companyId])
}

model PipelineStage {
  id          String @id @default(cuid())
  workspaceId String
  name        String
  order       Int
  probability Int    @default(0) // 0-100, weighted forecasting input for Phase 9 Analytics

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deals     Deal[]

  @@unique([workspaceId, order])
}

enum DealStatus {
  OPEN
  WON
  LOST
}

model Deal {
  id                String     @id @default(cuid())
  workspaceId       String
  companyId         String?
  contactId         String?
  stageId           String
  title             String
  valueCents        Int        @default(0)
  currency          String     @default("USD")
  status            DealStatus @default(OPEN)
  expectedCloseDate DateTime?
  ownerId           String // FK -> Better Auth User.id
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  workspace    Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company      Company?           @relation(fields: [companyId], references: [id])
  contact      Contact?           @relation(fields: [contactId], references: [id])
  stage        PipelineStage      @relation(fields: [stageId], references: [id])
  stageHistory DealStageHistory[]

  @@index([workspaceId, stageId])
  @@index([ownerId])
}

// Append-only — audit trail of pipeline movement, feeds Phase 9 forecasting.
model DealStageHistory {
  id          String   @id @default(cuid())
  dealId      String
  fromStageId String?
  toStageId   String
  changedById String
  changedAt   DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, changedAt])
}
