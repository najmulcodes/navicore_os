# Copy to .env and fill in. Validated at boot by packages/config (fails fast on
# missing/invalid values — see packages/config/src/env.ts).

NODE_ENV=development

# --- Database (Prisma 7 + Supabase Supavisor pooler) ---------------------
# Local dev (docker compose up -d postgres): both vars point at the same
# local container — there's no pooler in front of it, so pooled vs. direct
# is a distinction without a difference locally.
DATABASE_URL="postgresql://navicore:navicore_dev_only@localhost:5432/navicore_os"
DIRECT_URL="postgresql://navicore:navicore_dev_only@localhost:5432/navicore_os"

# Staging/production (Supabase): DATABASE_URL is the pooled Supavisor connection
# (transaction mode, used by apps/api and apps/ai-service at runtime) and
# DIRECT_URL is the unpooled connection (used only by `prisma migrate`/`studio`).
# See docs/adr/004-hosting-split.md, Action Item 3.
#   DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
#   DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# --- Redis (BullMQ in Phase 2+; health check now) -------------------------
# Local dev (docker compose up -d redis):
REDIS_URL="redis://localhost:6379"
# Staging/production: Railway-managed Redis connection string.

# --- apps/api ---------------------------------------------------------------
API_PORT=3001

# --- AI Layer (Phase 6) --------------------------------------------------
AI_SERVICE_URL="http://localhost:8000"
# Shared secret apps/api sends to apps/ai-service — the AI service isn't
# meant to be reachable directly, only from apps/api. Same value on both
# sides (ai-service reads it as INTERNAL_API_KEY — see apps/ai-service/.env.example).
INTERNAL_AI_API_KEY="replace-with-a-real-random-secret"
ANTHROPIC_API_KEY=

# --- Better Auth (Milestone 1.2) --------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-real-32+-char-secret"
BETTER_AUTH_URL="http://localhost:3001"

# Optional — email/password auth works with neither configured. If set, both
# id and secret must be present for that provider (validated at boot).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
