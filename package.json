    "tsx": "^4.23.1",
    "turbo": "^2.10.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.64.0"
  },
  "pnpm": {
    "overrides": {
      "sharp": "^0.35.3",
      "fast-uri": "^4.1.1",
