# Copy to .env in this directory (apps/ai-service/.env) for local dev, or set
# these directly in Railway's environment for deployment.

AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Must match INTERNAL_AI_API_KEY in the root .env — apps/api sends this on
# every request; see app/auth.py.
INTERNAL_API_KEY=replace-with-a-real-random-secret

PORT=8000
