packages/db/generated/

# Env files — .env.example is the only one committed
.env
.env.local
.env.*.local
.env.production

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store

# Test coverage
coverage/

# Docker local volumes (see docker-compose.yml)
.docker-data/
